name: Build Lesis Engine
on: [push]
jobs:
  build:
    runs-on: windows-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Setup MSVC
        uses: ilammy/msvc-dev-cmd@v1

      - name: Compile Engine
        run: |
          cl.exe /O2 /MT /EHsc lesis_engine.cpp /Fe:LesisEngine.exe /D_CRT_SECURE_NO_WARNINGS /link /NODEFAULTLIB:libcmtd
        # Bu komut lesis_engine.cpp dosyasını arayıp LesisEngine.exe yapacak.

      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: LesisEngine-Artifact
          path: LesisEngine.exe
